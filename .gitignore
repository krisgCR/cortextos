node_modules/
# npm-only repo (tracks upstream npm fork) — block stray pnpm/yarn artifacts.
# Enforced at install time by the "preinstall" guard in package.json.
pnpm-lock.yaml
pnpm-workspace.yaml
yarn.lock
.claude/
!.claude/commands/
!.claude/commands/**
!.claude/orchestration-cortextos-node/
# Include template .claude dirs (needed for agent settings.json)
!templates/**/.claude/
!templates/**/.claude/**
dist/
ecosystem.config.js

# User-created org data (not part of the framework)
orgs/
# But community subdirectories ARE part of the framework
!community/
!community/**

# Secrets
.env
!.env.example
templates/*/.env
.cortextos-env

# Agent runtime data
orgs/*/agents/*/memory/
agents/*/local/
agents/*/telegram-images/
agents/*/memory/

# macOS metadata
.DS_Store

# Test artifacts
test-results/
*.log
# Dashboard SQLite cache fallback (db.ts uses .data/ when CTX_ROOT is unset) — runtime data, never commit
.data/
# Spurious directory created when ${APPDATA} env var unexpanded during npm link on Windows
${APPDATA}/

# Knowledge base
knowledge-base/venv/
knowledge-base/__pycache__/
knowledge-base/scripts/__pycache__/
knowledge-base/scripts/_test_clients/__pycache__/
tests/playwright/dashboard-ui.spec.ts

# Local ops docs (personal, not for public repo)
docs/

# Internal developer/planning notes (not for public repo)
KNOWN-ISSUES.md
WINDOWS-IMPLEMENTATION-PLAN.md
WINDOWS-SUPPORT-INVESTIGATION.md
BRAINDUMP*.md
AGENTS.md
# ...except the repo-root AGENTS.md — the cross-tool source of truth that CLAUDE.md imports.
!/AGENTS.md
dashboard/screenshots/
dashboard/test-*.py

# Public community agent templates may intentionally include their own docs,
# AGENTS.md, memory skill, and scaffold files.
!community/agents/research-agent/
!community/agents/research-agent/**

# Internal overseer-fork planning (roadmap, journal, WORK.md, context) — keep local, never push to public fork
.planning/

# Serena LSP project cache (local tooling, not for public fork)
.serena/

# Stray Next.js build output at repo root (the real build lives under dashboard/)
/.next/
